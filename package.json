{
  "name": "@jssuite/vizat",
  "version": "2.0.0",
  "description": "Vizat — blazing-fast HTML5 Canvas 2D scene-tree library",
  "type": "module",
  "main": "./dist/vizat.umd.cjs",
  "module": "./dist/vizat.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vizat.js",
      "require": "./dist/vizat.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --emitDeclarationOnly && vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JsSuite/vizat.git"
  },
  "homepage": "https://vizat.vercel.app",
  "keywords": [
    "canvas",
    "2d",
    "graphics",
    "vizat",
    "html5"
  ],
  "author": "m3yevn",
  "license": "MIT",
  "devDependencies": {
    "happy-dom": "^20.10.4",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
